services:
  db:
    image: postgres:17
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER}"]
      interval: 5s
      timeout: 5s
      retries: 5
    env_file: ".env"

  api:
    image: ghcr.io/leoklaus/localez-backend:latest
    depends_on:
      db:
        condition: service_healthy
    env_file: ".env"

  frontend:
    image: ghcr.io/leoklaus/localez-backend:latest
    volumes:
      - ./legal:/usr/share/nginx/html/legal
    depends_on:
      - api
    env_file: ".env"
    ports:
      - "3000:80"

volumes:
  postgres_data:
